generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())

  ownedProjects      Project[]
  collaborations     ProjectCollaborator[]
  sentInvites        CollaboratorInvite[]  @relation("InvitedBy")
  passwordResets     PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  shareToken  String   @unique @default(cuid())
  config      Json
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  collaborators ProjectCollaborator[]
  invites       CollaboratorInvite[]
  sessions      TestSession[]
  analysisResults AnalysisResult[]
}

model AnalysisResult {
  id          String   @id @default(cuid())
  projectId   String
  analysisKey String
  paramsHash  String
  result      Json
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, analysisKey, paramsHash])
  @@index([projectId])
}

model ProjectCollaborator {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model CollaboratorInvite {
  id          String    @id @default(cuid())
  projectId   String
  inviteeEmail String
  token       String    @unique @default(cuid())
  invitedById String
  accepted    Boolean   @default(false)
  createdAt   DateTime  @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedBy  User    @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
}

model TestSession {
  id            String    @id @default(cuid())
  projectId     String
  participantId String
  takerEmail    String
  takerAge      String
  takerHandedness String
  takerEducation  String
  startedAt     DateTime
  finishedAt    DateTime?
  consentGiven  Boolean   @default(false)
  demographics  Json?
  globalTLX     Json?
  customAnswers Json?
  clientSubmissionId String? @unique
  createdAt     DateTime  @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blocks  TestBlock[]

  @@index([takerEmail])
  @@index([projectId])
}

model TestBlock {
  id            String   @id @default(cuid())
  sessionId     String
  blockIndex    Int
  stimulusType  String
  level         Int
  perLevelTLX   Json?

  session TestSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  trials  TestTrial[]

  @@index([sessionId])
}

model TestTrial {
  id            String  @id @default(cuid())
  blockId       String
  trialIndex    Int
  stimulus      String
  isPriming     Boolean
  expectedMatch Boolean?
  responded     Boolean
  responseYes   Boolean?
  rtMs          Float?
  correct       Boolean?
  onsetTs       Float

  block TestBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
}

// Legacy model kept for backwards compatibility
model Session {
  id            String    @id @default(cuid())
  participantId String
  startedAt     DateTime
  finishedAt    DateTime?
  config        Json
  consentGiven  Boolean   @default(false)
  consentTs     DateTime?
  demographics  Json?
  globalTLX     Json?
  customAnswers Json?
  clientSubmissionId String? @unique
  createdAt     DateTime  @default(now())

  blocks Block[]
}

model Block {
  id           String  @id @default(cuid())
  sessionId    String
  blockIndex   Int
  stimulusType String
  level        Int
  perLevelTLX  Json?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  trials  Trial[]
}

model Trial {
  id            String  @id @default(cuid())
  blockId       String
  trialIndex    Int
  stimulus      String
  isPriming     Boolean
  expectedMatch Boolean?
  responded     Boolean
  responseYes   Boolean?
  rtMs          Float?
  correct       Boolean?
  onsetTs       Float

  block Block @relation(fields: [blockId], references: [id], onDelete: Cascade)
}
